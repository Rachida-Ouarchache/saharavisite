# CRA: variables must be prefixed with REACT_APP_
DANGEROUSLY_DISABLE_HOST_CHECK=true

# Numéro WhatsApp business (indicatif pays + numéro, sans + dans la valeur)
# Exemple Maroc: 212760479374
REACT_APP_WHATSAPP_NUMBER=212760479374

# Optionnel: message pré-rempli dans WhatsApp
# REACT_APP_WHATSAPP_MESSAGE=Bonjour, je souhaite des infos sur une expérience TripNexa
